generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  MANAGER
  STAFF
}

enum ClientType {
  COMPANY
  INDIVIDUAL
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum ExpatStatus {
  PENDING
  ACTIVE
  TRANSFERRED
  EXPIRED
  REPATRIATED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EntityType {
  EXPAT
  CLIENT
  DORMITORY
}

enum ChecklistScope {
  GLOBAL
  CUSTOM
}

enum ChecklistStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum ChecklistItemStatus {
  PENDING
  DONE
  WAIVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model User {
  id                  String    @id @default(cuid())
  emailHash           String    @unique
  emailEncrypted      String
  passwordHash        String
  name                String?
  role                Role      @default(STAFF)
  isActive            Boolean   @default(true)
  emailVerified       Boolean   @default(false)
  otpSecret           String?
  otpEnabled          Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  refreshToken        String?
  emailVerifyToken    String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  notifications Notification[]
  auditLogs     AuditLog[]
}

model SystemSettings {
  id                       String   @id @default("system")
  appName                  String   @default("Talentius Hub")
  appLogo                  String?
  accentColor              String   @default("#1F4E3D")
  timezone                 String   @default("Asia/Kuala_Lumpur")
  dateFormat               String   @default("DD MMM YYYY")
  pageSize                 Int      @default(25)
  docAlertDays1            Int      @default(30)
  docAlertDays2            Int      @default(7)
  checklistOverdueDays     Int      @default(7)
  transferRequiresApproval Boolean  @default(true)
  maxFileSize              Int      @default(10485760)
  allowedMimeTypes         String[] @default(["application/pdf", "image/jpeg", "image/png", "image/webp"])
  loginMaxAttempts         Int      @default(5)
  loginLockoutMinutes      Int      @default(15)
  otpTtlMinutes            Int      @default(10)
  dashboardWidgets         String[] @default(["kpi", "alerts", "transfers", "occupancy"])
  emailRecipients          Json     @default("{}")
  updatedAt                DateTime @updatedAt
}

model WebhookConfig {
  id         String   @id @default(cuid())
  name       String
  eventType  String
  url        String
  secret     String?
  retryCount Int      @default(3)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  deliveries WebhookDeliveryLog[]
}

model WebhookDeliveryLog {
  id        String        @id @default(cuid())
  webhookId String
  webhook   WebhookConfig @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventType String
  payload   Json
  statusCode Int?
  response  String?
  success   Boolean
  attempts  Int      @default(1)
  createdAt DateTime @default(now())
}

model Client {
  id               String       @id @default(cuid())
  clientNo         Int          @unique @default(autoincrement())
  type             ClientType
  name             String
  registrationNoEnc String?
  contactNameEnc   String?
  contactPhoneEnc  String?
  contactEmailEnc  String?
  contactEmailHash String?
  address          String?
  status           EntityStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  expats          Expat[]
  dormAssignments DormitoryAssignment[]
  transfersFrom   ExpatTransfer[]       @relation("TransferFromClient")
  transfersTo     ExpatTransfer[]       @relation("TransferToClient")
}

model Dormitory {
  id          String       @id @default(cuid())
  dormitoryNo Int          @unique @default(autoincrement())
  name        String
  address     String
  state       String
  capacity    Int
  pic         String?
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  expats            Expat[]
  clientAssignments DormitoryAssignment[]
  transfersFrom     ExpatTransfer[]       @relation("TransferFromDorm")
  transfersTo       ExpatTransfer[]       @relation("TransferToDorm")
}

model DormitoryAssignment {
  id          String    @id @default(cuid())
  dormitoryId String
  dormitory   Dormitory @relation(fields: [dormitoryId], references: [id])
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  assignedAt  DateTime  @default(now())
  assignedBy  String
  removedAt   DateTime?
  removedBy   String?
}

model Expat {
  id             String      @id @default(cuid())
  expatNo        String      @unique
  clientId       String?
  client         Client?     @relation(fields: [clientId], references: [id])
  dormitoryId    String?
  dormitory      Dormitory?  @relation(fields: [dormitoryId], references: [id])
  fullName       String
  passportNoEnc  String
  nationality    String
  dateOfBirthEnc String?
  phoneEnc       String?
  status         ExpatStatus @default(PENDING)
  permitExpiry   DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  transfers ExpatTransfer[]
}

model ExpatTransfer {
  id              String         @id @default(cuid())
  expatId         String
  expat           Expat          @relation(fields: [expatId], references: [id])
  fromDormitoryId String?
  fromDormitory   Dormitory?     @relation("TransferFromDorm", fields: [fromDormitoryId], references: [id])
  toDormitoryId   String?
  toDormitory     Dormitory?     @relation("TransferToDorm", fields: [toDormitoryId], references: [id])
  fromClientId    String?
  fromClient      Client?        @relation("TransferFromClient", fields: [fromClientId], references: [id])
  toClientId      String?
  toClient        Client?        @relation("TransferToClient", fields: [toClientId], references: [id])
  reason          String
  status          TransferStatus @default(PENDING)
  requestedBy     String
  approvedBy      String?
  rejectedBy      String?
  rejectionReason String?
  effectiveDate   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// Documents use entityType + entityId (polymorphic, no Prisma FK)
model Document {
  id               String     @id @default(cuid())
  entityType       EntityType
  entityId         String
  documentType     String
  originalName     String
  storedName       String     @unique
  filePath         String
  mimeType         String
  fileSizeBytes    Int
  expiryDate       DateTime?
  alertSent1       Boolean    @default(false)
  alertSent2       Boolean    @default(false)
  alertSentExpired Boolean    @default(false)
  uploadedBy       String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([entityType, entityId])
  @@index([expiryDate])
}

model ChecklistTemplate {
  id         String         @id @default(cuid())
  name       String
  entityType EntityType
  scope      ChecklistScope @default(GLOBAL)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  items      ChecklistTemplateItem[]
  checklists Checklist[]
}

model ChecklistTemplateItem {
  id         String            @id @default(cuid())
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  itemText   String
  order      Int
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

// Checklists use entityType + entityId (polymorphic, no Prisma FK)
model Checklist {
  id         String          @id @default(cuid())
  templateId String?
  template   ChecklistTemplate? @relation(fields: [templateId], references: [id])
  entityType EntityType
  entityId   String
  name       String
  status     ChecklistStatus @default(IN_PROGRESS)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  items ChecklistItem[]

  @@index([entityType, entityId])
}

model ChecklistItem {
  id           String              @id @default(cuid())
  checklistId  String
  checklist    Checklist           @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  itemText     String
  order        Int
  status       ChecklistItemStatus @default(PENDING)
  completedBy  String?
  completedAt  DateTime?
  waivedBy     String?
  waivedReason String?
  overdueSince DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model AuditLog {
  id              String      @id @default(cuid())
  tableName       String
  recordId        String
  fieldName       String?
  valueFrom       String?
  valueTo         String?
  action          AuditAction
  performedBy     String?
  performedByUser User?       @relation(fields: [performedBy], references: [id])
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime    @default(now())

  @@index([tableName, recordId])
  @@index([performedBy])
  @@index([createdAt])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  body       String
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, isRead])
}

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
TZ=Indian/Mauritius

# Database
DATABASE_URL=postgresql://user:password@host:5432/expatflow

# Security
JWT_SECRET=your-256-bit-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-256-bit-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=7d
ENCRYPTION_KEY=64-char-hex-string-for-32-bytes

# SendGrid
SENDGRID_API_KEY=SG.xxxxxx
SENDGRID_FROM_EMAIL=noreply@expatflow.com
SENDGRID_TEMPLATE_OTP=d-xxxxxxxx
SENDGRID_TEMPLATE_EMAIL_VERIFY=d-xxxxxxxx
SENDGRID_TEMPLATE_DOC_ALERT=d-xxxxxxxx
SENDGRID_TEMPLATE_DOC_EXPIRED=d-xxxxxxxx
SENDGRID_TEMPLATE_TRANSFER_PENDING=d-xxxxxxxx
SENDGRID_TEMPLATE_TRANSFER_APPROVED=d-xxxxxxxx
SENDGRID_TEMPLATE_CHECKLIST_OVERDUE=d-xxxxxxxx

# File Storage
UPLOAD_DIR=/data/uploads

